# Copy this file to .env and fill in your values. .env is gitignored.

# ── Collaps online source ─────────────────────────────────────────────────────
# API key for kinopoiskapiunofficial.tech (title → kinopoisk_id fallback when a
# TMDB title has no imdb_id). Get a free key at
# https://kinopoiskapiunofficial.tech (register → profile → API key).
# Optional: if unset, the community key bundled with Lampa is used as a fallback.
COLLAPS_KP_API_KEY=

# ── TMDB ──────────────────────────────────────────────────────────────────────
# A TMDB Read Access Token (v4 bearer). The app asks for it on first run and
# stores it encrypted in the OS keychain (Electron safeStorage), so you normally
# do NOT need to set it here. This env var is only used if you want to pre-seed
# it (e.g. for automated setups). Get one at https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=
